{
  "name": "docmd-search",
  "version": "0.1.0",
  "description": "Offline semantic search for everyone. Zero runtime deps, works with any docs.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docmd-search": "dist/bin/docmd-search.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js --watch",
    "prep": "npm run reset && npm run verify",
    "verify": "node --experimental-vm-modules scripts/failsafe.js",
    "typecheck": "npx tsc --noEmit --project tsconfig.base.json",
    "clean": "rm -rf dist node_modules *.tsbuildinfo tsconfig.check.json > /dev/null 2>&1 || true",
    "reset": "npm run clean && npm install --silent && npm run build"
  },
  "keywords": [
    "search",
    "semantic-search",
    "offline",
    "client-side",
    "vector-search",
    "documentation",
    "ai"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd-search.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd-search/issues"
  },
  "homepage": "https://docmd.io/search",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.25.0",
    "onnxruntime-node": "^1.24.3",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@huggingface/transformers": "^4.0.0",
    "onnxruntime-node": "^1.20.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "onnxruntime-node": {
      "optional": true
    }
  }
}
