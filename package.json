{
  "name": "docmd-search",
  "version": "0.1.0-alpha.1",
  "description": "Offline semantic search engine for documentation. Local embeddings, browser-ready indexes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "docmd-search": "dist/bin/docmd-search.js"
  },
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js --watch",
    "prep": "npm run reset && npm run verify",
    "verify": "node --experimental-vm-modules scripts/failsafe.js",
    "typecheck": "npx tsc --noEmit --project tsconfig.base.json",
    "clean": "rm -rf dist node_modules *.tsbuildinfo tsconfig.check.json > /dev/null 2>&1 || true",
    "reset": "npm run clean && npm install --silent && npm run build"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "onnxruntime-node": "^1.26.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@docmd/engine-js": ">=0.8.5",
    "@docmd/engine-rust": ">=0.8.5",
    "@huggingface/transformers": "^4.2.0",
    "onnxruntime-node": "^1.26.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    },
    "onnxruntime-node": {
      "optional": true
    },
    "@docmd/engine-rust": {
      "optional": true
    },
    "@docmd/engine-js": {
      "optional": true
    }
  },
  "keywords": [
    "search",
    "semantic-search",
    "offline",
    "client-side",
    "vector-search",
    "documentation",
    "embeddings"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd-search.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd-search/issues"
  },
  "homepage": "https://docmd.io/search",
  "license": "MIT"
}